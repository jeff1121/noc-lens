{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "noc-lens",
  "version": "0.1.0",
  "identifier": "com.noclens.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "noc-lens",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
